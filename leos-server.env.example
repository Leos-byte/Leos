# Copy to leos-server.env and fill in real values. Never commit leos-server.env.
# Secrets are environment-only by design: putting them in leos-server.toml fails startup.

# Required: API key for every non-health endpoint (32+ bytes; generate with
#   python -c "import secrets; print(secrets.token_hex(32))")
LEOS_SERVER_API_KEY=change-me-generate-a-random-64-hex-char-value

# Required for signing approval decisions (/approvals/decide, /apply, inbox):
LEOS_APPROVAL_HMAC_SECRET=change-me-generate-another-random-value

# Required only for /apply against real GitHub (fine-grained PAT, disposable scope):
# LEOS_GITHUB_TOKEN=
# LEOS_ENABLE_REAL_GITHUB_WRITES=1

# Postgres credentials for the optional store/queue backends (compose service):
POSTGRES_PASSWORD=change-me-postgres-password
# LEOS_TEST_POSTGRES_DSN=postgresql://postgres:${POSTGRES_PASSWORD}@postgres:5432/postgres
